PORT=3000
APP_BASE_URL=https://api.wikapacking.com

ALIBABA_CLIENT_ID=506918
ALIBABA_CLIENT_SECRET=replace_with_real_client_secret
ALIBABA_REDIRECT_URI=https://api.wikapacking.com/integrations/alibaba/callback
ALIBABA_AUTH_URL=https://open-api.alibaba.com/oauth/authorize
ALIBABA_TOKEN_URL=https://open-api.alibaba.com/rest/auth/token/create
ALIBABA_REFRESH_TOKEN_URL=https://open-api.alibaba.com/rest/auth/token/refresh
SESSION_SECRET=replace_with_random_session_secret

# Optional. Some Alibaba examples include partner_id in token requests.
ALIBABA_PARTNER_ID=codex-alibaba-callback

# Wika single-store token persistence and auto-refresh settings.
ALIBABA_WIKA_TOKEN_STORAGE_PATH=./data/alibaba/runtime/wika-token.json
ALIBABA_WIKA_AUTO_REFRESH_ENABLED=true
ALIBABA_WIKA_REFRESH_BUFFER_SECONDS=600

# Optional bootstrap value when you already have a valid refresh token but no token file yet.
ALIBABA_WIKA_BOOTSTRAP_REFRESH_TOKEN=replace_with_existing_refresh_token_if_needed

# XD store OAuth configuration. Use a different Alibaba app and callback from WIKA.
ALIBABA_XD_CLIENT_ID=replace_with_xd_client_id
ALIBABA_XD_CLIENT_SECRET=replace_with_xd_client_secret
ALIBABA_XD_REDIRECT_URI=https://api.wikapacking.com/integrations/alibaba/xd/auth/callback
ALIBABA_XD_AUTH_URL=https://open-api.alibaba.com/oauth/authorize
ALIBABA_XD_TOKEN_URL=https://open-api.alibaba.com/rest/auth/token/create
ALIBABA_XD_REFRESH_TOKEN_URL=https://open-api.alibaba.com/rest/auth/token/refresh

# Optional. Some Alibaba examples include partner_id in token requests.
ALIBABA_XD_PARTNER_ID=codex-alibaba-xd-callback

# XD single-store token persistence and auto-refresh settings.
ALIBABA_XD_TOKEN_STORAGE_PATH=./data/alibaba/runtime/xd-token.json
ALIBABA_XD_AUTO_REFRESH_ENABLED=true
ALIBABA_XD_REFRESH_BUFFER_SECONDS=600

# Optional bootstrap value when XD already has a valid refresh token but no token file yet.
ALIBABA_XD_BOOTSTRAP_REFRESH_TOKEN=replace_with_xd_refresh_token_if_needed
